# ============================================
# MediaSeerr — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul je waarden in
# ============================================

# TMDB API key (gratis via https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# --- Mediaserver (kies er één of beide) ---

# Jellyfin
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

# Plex
PLEX_URL=http://plex:32400
PLEX_TOKEN=

# --- Download Clients ---

# Radarr (films)
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Sonarr (series)
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=
